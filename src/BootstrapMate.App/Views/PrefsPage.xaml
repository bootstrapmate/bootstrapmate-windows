<Page
    x:Class="BootstrapMate.App.Views.PrefsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:BootstrapMate.App.ViewModels"
    NavigationCacheMode="Required">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer Padding="28,24,28,24">
            <StackPanel Spacing="20" MaxWidth="960" HorizontalAlignment="Center">

            <!-- ═══ App Info Header ═══ -->
            <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="0,8,0,4">
                <Image x:Name="AppIcon" Width="64" Height="64" HorizontalAlignment="Center" />

                <TextBlock Text="BootstrapMate"
                           Style="{StaticResource TitleTextBlockStyle}"
                           HorizontalAlignment="Center" />

                <TextBlock Text="Enterprise management tools provisioning for automated device setup using manifests."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextAlignment="Center" MaxWidth="500"
                           TextWrapping="WrapWholeWords" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                    <HyperlinkButton Content="Documentation"
                                     NavigateUri="https://github.com/bootstrapmate/bootstrapmate-windows/wiki" />
                    <HyperlinkButton Content="Report Issue"
                                     NavigateUri="https://github.com/bootstrapmate/bootstrapmate-windows/issues" />
                </StackPanel>

                <TextBlock Text="{x:Bind ViewModel.VersionDisplay, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- ═══ Settings Grid: 2×2 card layout ═══ -->
            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ── Connection Card ── -->
                <Border Grid.Row="0" Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,4">
                        <FontIcon Glyph="&#xE943;" FontSize="20"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Connection" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Manifest URL -->
                    <TextBlock Text="Manifest URL" Style="{StaticResource CaptionTextBlockStyle}" />
                    <Grid ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{x:Bind ViewModel.ManifestUrl, Mode=TwoWay}"
                                 PlaceholderText="https://example.com/bootstrapmate.json"
                                 IsEnabled="{x:Bind ViewModel.IsManifestUrlLocked, Mode=OneWay, Converter={StaticResource InvertBool}}" />
                        <Button Grid.Column="1" x:Name="PreviewManifestButton"
                                ToolTipService.ToolTip="Preview manifest content"
                                Click="PreviewManifestButton_Click"
                                Width="36" Padding="6">
                            <FontIcon Glyph="&#xE7B3;" FontSize="14" />
                            <Button.Flyout>
                                <Flyout x:Name="ManifestPreviewFlyout" Placement="BottomEdgeAlignedLeft">
                                    <Flyout.FlyoutPresenterStyle>
                                        <Style TargetType="FlyoutPresenter">
                                            <Setter Property="MaxWidth" Value="9999" />
                                            <Setter Property="Padding" Value="16" />
                                        </Style>
                                    </Flyout.FlyoutPresenterStyle>
                                    <StackPanel Width="640" Spacing="10">
                                        <!-- Flyout header -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Manifest Preview"
                                                       Style="{StaticResource SubtitleTextBlockStyle}"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        Spacing="8" VerticalAlignment="Center">
                                                <ProgressRing IsActive="{x:Bind ViewModel.IsManifestPreviewLoading, Mode=OneWay}"
                                                              Width="18" Height="18" />
                                                <Button x:Name="RefreshPreviewButton"
                                                        ToolTipService.ToolTip="Refresh"
                                                        Click="PreviewManifestButton_Click"
                                                        Width="32" Height="32" Padding="0">
                                                    <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                        <!-- Error message -->
                                        <TextBlock Text="{x:Bind ViewModel.ManifestPreviewError, Mode=OneWay}"
                                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{x:Bind ViewModel.HasManifestPreviewError, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                        <!-- Content -->
                                        <ScrollViewer MaxHeight="420"
                                                      Visibility="{x:Bind ViewModel.HasManifestPreviewContent, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{x:Bind ViewModel.ManifestPreviewContent, Mode=OneWay}"
                                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       IsTextSelectionEnabled="True" />
                                        </ScrollViewer>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.IsManifestUrlLocked, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE72E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Managed by Policy" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- Authorization Header -->
                    <TextBlock Text="Authorization Header" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                    <PasswordBox Password="{x:Bind ViewModel.AuthorizationHeader, Mode=TwoWay}"
                                 PlaceholderText="{x:Bind ViewModel.AuthPlaceholderText, Mode=OneWay}"
                                 IsEnabled="{x:Bind ViewModel.IsAuthHeaderLocked, Mode=OneWay, Converter={StaticResource InvertBool}}" />
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.IsAuthHeaderLocked, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE72E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Managed by Policy" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- Follow Redirects -->
                    <ToggleSwitch Margin="0,4,0,0" OnContent="Follow HTTP Redirects" OffContent="Follow HTTP Redirects"
                                  IsOn="{x:Bind ViewModel.FollowRedirects, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsFollowRedirectsLocked, Mode=OneWay, Converter={StaticResource InvertBool}}" />
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.IsFollowRedirectsLocked, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE72E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Managed by Policy" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
                </Border>

                <!-- ── Behavior Card ── -->
                <Border Grid.Row="0" Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,4">
                        <FontIcon Glyph="&#xE713;" FontSize="20"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Behavior" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <ToggleSwitch OnContent="Reboot after completion" OffContent="Reboot after completion"
                                  IsOn="{x:Bind ViewModel.Reboot, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsRebootLocked, Mode=OneWay, Converter={StaticResource InvertBool}}" />
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.IsRebootLocked, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE72E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Managed by Policy" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <ToggleSwitch OnContent="Suppress console output" OffContent="Suppress console output"
                                  IsOn="{x:Bind ViewModel.SilentMode, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsSilentModeLocked, Mode=OneWay, Converter={StaticResource InvertBool}}" />
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.IsSilentModeLocked, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE72E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Managed by Policy" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <ToggleSwitch OnContent="Enable verbose logging" OffContent="Enable verbose logging"
                                  IsOn="{x:Bind ViewModel.VerboseMode, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsVerboseModeLocked, Mode=OneWay, Converter={StaticResource InvertBool}}" />
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.IsVerboseModeLocked, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE72E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Managed by Policy" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <ToggleSwitch OnContent="Dry run (no installs)" OffContent="Dry run (no installs)"
                                  IsOn="{x:Bind ViewModel.DryRun, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsDryRunLocked, Mode=OneWay, Converter={StaticResource InvertBool}}" />
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.IsDryRunLocked, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE72E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Managed by Policy" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
                </Border>

                <!-- ── Dialog Card ── -->
                <Border Grid.Row="1" Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,4">
                        <FontIcon Glyph="&#xE8F2;" FontSize="20"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Dialog" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <ToggleSwitch OnContent="Show progress dialog" OffContent="Show progress dialog"
                                  IsOn="{x:Bind ViewModel.EnableDialog, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsEnableDialogLocked, Mode=OneWay, Converter={StaticResource InvertBool}}" />
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.IsEnableDialogLocked, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE72E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Managed by Policy" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <TextBlock Text="Title" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                    <TextBox Text="{x:Bind ViewModel.DialogTitle, Mode=TwoWay}" PlaceholderText="Setting Up Your Device" />

                    <TextBlock Text="Message" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                    <TextBox Text="{x:Bind ViewModel.DialogMessage, Mode=TwoWay}" PlaceholderText="Please wait while we install required software..." />

                    <TextBlock Text="Icon" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                    <TextBox Text="{x:Bind ViewModel.DialogIcon, Mode=TwoWay}" PlaceholderText="Path to icon file (.ico, .png)" />

                    <ToggleSwitch Margin="0,4,0,0" OnContent="Blur screen behind dialog" OffContent="Blur screen behind dialog"
                                  IsOn="{x:Bind ViewModel.BlurScreen, Mode=TwoWay}" />
                </StackPanel>
                </Border>

                <!-- ── Advanced Card ── -->
                <Border Grid.Row="1" Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,4">
                        <FontIcon Glyph="&#xE90F;" FontSize="20"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Advanced" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="Custom Install Path" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox Text="{x:Bind ViewModel.CustomInstallPath, Mode=TwoWay}"
                             PlaceholderText="C:\Program Files\BootstrapMate"
                             IsEnabled="{x:Bind ViewModel.IsCustomInstallPathLocked, Mode=OneWay, Converter={StaticResource InvertBool}}" />
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.IsCustomInstallPathLocked, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE72E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Managed by Policy" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <TextBlock Text="Network Timeout" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,4,0,0" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <NumberBox Value="{x:Bind ViewModel.NetworkTimeoutValue, Mode=TwoWay}" Minimum="10" Maximum="600"
                                   SpinButtonPlacementMode="Compact" SmallChange="10"
                                   Width="120"
                                   IsEnabled="{x:Bind ViewModel.IsNetworkTimeoutLocked, Mode=OneWay, Converter={StaticResource InvertBool}}" />
                        <TextBlock Text="seconds" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                Visibility="{x:Bind ViewModel.IsNetworkTimeoutLocked, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE72E;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Managed by Policy" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
    </Grid>
</Page>
